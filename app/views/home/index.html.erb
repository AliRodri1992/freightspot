<h1>Home#index</h1>
<%= user_signed_in? %>
<% if user_signed_in? %>
  <h1>logueado</h1>
  <%= link_to 'Log out', destroy_user_session_path, data: { turbo_method: :delete }, class: 'btn btn-primary' %>

<% else %>
  <h1>no logueado</h1>
  <%= link_to 'Log in', new_user_session_path, class: 'btn btn-primary' %>
<% end %>
